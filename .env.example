# Copy to .env and fill in real values.
# Get them from the browser: DevTools -> Network -> TweetResultByRestId request -> headers.
# .env is NOT committed to git (see .gitignore).

# ID of the tweet to notarize
TWEET_ID=

# Full Cookie header (needs at least auth_token, ct0, twid)
X_COOKIE=auth_token=...; ct0=...; twid=...

# authorization header (Bearer ...)
X_AUTHORIZATION=Bearer AAAAAAAA...

# x-csrf-token header (matches the ct0 value from the cookie)
X_CSRF_TOKEN=

# (Optional) Override the GraphQL request URL if x.com changed queryId/features.
# Copy the fresh request from DevTools, replace tweetId with {tweet_id}.
# Defaults to the URL hardcoded in the source.
# TWEET_URL=https://x.com/i/api/graphql/.../TweetResultByRestId?variables=...{tweet_id}...&features=...
